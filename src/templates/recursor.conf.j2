local-address={{ ENV_RECURSOR_LOCAL_ADDRESS }}
local-port={{ ENV_RECURSOR_LOCAL_PORT }}
allow-from={{ ENV_RECURSOR_ALLOW_FROM }}
query-local-address={{ ENV_RECURSOR_QUERY_ADDRESS }}
config-dir=/etc/powerdns
hint-file=/usr/share/dns/root.hints
include-dir=/etc/powerdns/recursor.d
quiet={{ ENV_RECURSOR_QUIET }}
use-incoming-edns-subnet={{ ENV_RECURSOR_ENABLE_EDNS }}
#security-poll-suffix= # TESTING SECURITY UPDATES NOTIFICATION
setgid=pdns
setuid=pdns
dnssec=validate
include-dir=/etc/powerdns/recursor.d/
socket-dir=/var/run/powerdns-recursor
socket-mode = 660
